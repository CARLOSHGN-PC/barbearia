rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Permite leitura pública de barbearia, serviços e configs do site
    match /barbers/{document=**} {
      allow read: if true;
      allow write: if true; // Temporário: Sem auth no sistema
    }
    match /services/{document=**} {
      allow read: if true;
      allow write: if true; // Temporário: Sem auth no sistema
    }
    match /config/{document=**} {
      allow read: if true;
      allow write: if true; // Temporário: Sem auth no sistema
    }

    // Agendamentos: Permite ler e escrever publicamente (temporário)
    match /appointments/{document=**} {
      allow read: if true;
      allow write: if true;
    }
  }
}